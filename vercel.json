{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/print-requests.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 60
    },
    "api/auth/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 60
    },
    "api/admin/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 60
    },
    "api/customer/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    },
    "api/track-order.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login.php"
    },
    {
      "source": "/api/auth/register",
      "destination": "/api/auth/register.php"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth/me.php"
    },
    {
      "source": "/api/print-requests",
      "destination": "/api/print-requests.php"
    },
    {
      "source": "/api/track-order",
      "destination": "/api/track-order.php"
    },
    {
      "source": "/api/admin/print-requests",
      "destination": "/api/admin/print-requests.php"
    },
    {
      "source": "/api/admin/print-requests/:id",
      "destination": "/api/admin/print-requests.php?id=:id"
    },
    {
      "source": "/api/admin/print-requests/:id/:action",
      "destination": "/api/admin/print-requests.php?id=:id&action=:action"
    },
    {
      "source": "/api/admin/files/:storedName",
      "destination": "/api/admin/file.php?storedName=:storedName"
    },
    {
      "source": "/api/customer/profile",
      "destination": "/api/customer/profile.php"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    },
    {
      "source": "/profile",
      "destination": "/pages/profile.html"
    },
    {
      "source": "/track-order",
      "destination": "/pages/track-order.html"
    }
  ]
}
